# Discord Bot Token
# Get yours at: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Database (don't change if using docker-compose)
DATABASE_URL=postgresql://botuser:botpass@postgres:5432/discordbot

# Redis (don't change if using docker-compose)
REDIS_URL=redis://redis:6379

# AI Service URL (don't change if using docker-compose)
AI_SERVICE_URL=http://ai-service:8000

# Log level: error, warn, info, debug
RUST_LOG=discord_bot=info
