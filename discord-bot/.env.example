# Discord Bot Token
# Discord Developer Portal'dan al: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Veritabanı (docker-compose kullanıyorsan değiştirme)
DATABASE_URL=postgresql://botuser:botpass@postgres:5432/discordbot

# Redis (docker-compose kullanıyorsan değiştirme)
REDIS_URL=redis://redis:6379

# AI Servis URL (docker-compose kullanıyorsa değiştirme)
AI_SERVICE_URL=http://ai-service:8000

# Log seviyesi: error, warn, info, debug
RUST_LOG=discord_bot=info
